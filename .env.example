# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (platform / GoElev8 account)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
PLATFORM_FEE_BPS=290

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_COST_PER_SEGMENT_CENTS=1

# Anthropic (AI reply suggestions)
ANTHROPIC_API_KEY=

# App
PORTAL_BASE_URL=https://portal.goelev8.ai

# Vapi webhook (POST /api/webhooks/vapi)
VAPI_WEBHOOK_SECRET=
DEFAULT_CLIENT_ID=

# Universal lead webhook (POST /api/webhooks/lead)
# Used by the /embed/track.js form-capture script and any client-site
# webhook. Header: X-GoElev8-Secret. Same value goes into
# window.GoElev8.secret on client websites.
GOELEV8_WEBHOOK_SECRET=
