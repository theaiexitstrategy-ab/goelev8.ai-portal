# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# Stripe (platform / GoElev8 account)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
PLATFORM_FEE_BPS=290

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_COST_PER_SEGMENT_CENTS=1

# Vapi
VAPI_API_KEY=

# Anthropic (AI reply suggestions)
ANTHROPIC_API_KEY=

# App
PORTAL_BASE_URL=https://portal.goelev8.ai
ISLAY_CLIENT_ID=islay_studios

# Vapi webhook (POST /api/webhooks/vapi)
VAPI_WEBHOOK_SECRET=
DEFAULT_CLIENT_ID=

# Universal lead webhook (POST /api/webhooks/lead)
GOELEV8_WEBHOOK_SECRET=

# Google Analytics GA4
# Primary server-side credentials used by /api/portal/ga4 and /api/portal/flex-r2s
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
# Alias read as a fallback by /api/portal/flex-r2s if GA4_SERVICE_ACCOUNT_JSON is unset
VITE_GA_SERVICE_ACCOUNT_KEY=
