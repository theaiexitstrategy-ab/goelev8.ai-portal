{
  "version": 2,
  "rewrites": [
    { "source": "/api/webhooks/lead", "destination": "/api/events?action=lead" },
    { "source": "/api/webhooks/vapi", "destination": "/api/events?action=vapi" },
    { "source": "/api/(.*)",         "destination": "/api/$1" },
    { "source": "/islaystudios/login", "destination": "/clients/islaystudios/login.html" },
    { "source": "/islaystudios/dashboard", "destination": "/clients/islaystudios/leads.html" },
    { "source": "/islaystudios/leads", "destination": "/clients/islaystudios/leads.html" },
    { "source": "/islaystudios/messages", "destination": "/clients/islaystudios/messages.html" },
    { "source": "/islaystudios/blasts", "destination": "/clients/islaystudios/blasts.html" },
    { "source": "/islaystudios/nudges", "destination": "/clients/islaystudios/nudges.html" },
    { "source": "/islaystudios/settings", "destination": "/clients/islaystudios/settings.html" },
    { "source": "/islaystudios/calls", "destination": "/clients/islaystudios/calls.html" },
    { "source": "/islaystudios/credits", "destination": "/clients/islaystudios/credits.html" },
    { "source": "/islaystudios/analytics", "destination": "/clients/islaystudios/analytics.html" },
    { "source": "/islaystudios/artists", "destination": "/clients/islaystudios/artists.html" },
    { "source": "/islaystudios/:file(.*\\.(js|css|png|jpg|svg|ico|json))", "destination": "/clients/islaystudios/:file" },
    { "source": "/islaystudios", "destination": "/clients/islaystudios/leads.html" },
    { "source": "/((?!api/|clients/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
