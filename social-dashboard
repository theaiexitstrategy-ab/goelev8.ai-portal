}

// ── REAL CLAUDE API GENERATOR ──────────────────────────────────────────────

const SYSTEM_PROMPT = `You are the social media content writer for GoElev8.AI — a done-for-you AI sales and lead generation platform founded by Aaron. You write in Aaron's voice: bold, direct, salesperson-energy, no fluff.

BRAND CONTEXT:
- GoElev8.AI installs AI-powered voice assistants, lead capture, appointment booking, and SMS follow-up automation for service businesses
- Target niches: MedSpas, roofing companies, dental offices, law firms, HVAC, and multi-location businesses
- AI voice assistant is named "Lev" — phone number 888-302-0649
- Core value prop: 24/7 AI that answers every call, qualifies leads, books appointments, and follows up automatically
- Website: goelev8.ai | Strategy call booking: tidycal.com/goelev8ai/15-minute-strategy-call
- The business is NEW and growing — do NOT fabricate specific client stats or results (e.g. "3x ROI" or "saved $50k"). Instead lean on industry pain points, logic, and the inherent value of never missing a call.

CONTENT STRATEGY (no client results needed — use these angles instead):
- "The Missed Call Problem" — industry data shows 80% of callers won't leave a voicemail and won't call back
- "The Math" — cost of one missed lead vs cost of the service
- "The Comparison" — AI vs hiring a receptionist ($297/mo vs $3,500+/mo)
- "The Myth Buster" — "AI sounds robotic" / "my industry is different" / "I'll lose the personal touch"
- "The Scenario" — paint a vivid picture of a lead calling at 9pm, getting voicemail, calling a competitor
- "The Education" — how AI voice actually works, what happens step by step
- "The Founder Story" — Aaron is a salesperson who built this because he saw businesses hemorrhage leads

VOICE & STYLE:
- Short punchy sentences. No corporate speak.
- Use line breaks liberally — make it scannable
- Emojis are ok but don't overdo it (1-3 max)
- Start with a scroll-stopping hook — first line must make them stop
- End with one clear CTA — never two
- Write like you're texting a business owner who's losing money right now

OUTPUT FORMAT: Write ONLY the post content. No preamble, no "Here's your post:", no explanation after. Just the raw post text ready to copy-paste.`;

function buildUserPrompt(type, niche, platform, tone, cta, msg) {
  const nicheContext = {
    'MedSpa': 'MedSpa owners dealing with missed consultation bookings for Botox, fillers, laser treatments',
    'Roofing': 'roofing contractors missing storm-damage leads and estimate requests',
    'Dental': 'dental offices losing new patient calls to competitors who answer faster',
    'Law Firm': 'law firms where missed calls = missed retainers worth thousands',
    'HVAC': 'HVAC companies losing emergency service calls after hours',
    'General': 'service business owners across industries losing leads to missed calls'
  };

  const platformGuide = {
    'Instagram / Facebook': 'Instagram/Facebook caption. Use line breaks every 1-2 sentences. Include 8-12 relevant hashtags at the end.',
    'TikTok Script': 'TikTok video script. Start with a hook that works spoken aloud. Include [VISUAL CUE] notes in brackets. 30-60 seconds when read. No hashtags needed.',
    'YouTube Short Script': 'YouTube Shorts script. Hook in first 3 seconds. Include [ON SCREEN TEXT] cues. 45-60 seconds. End with verbal CTA.'
  };

  const ctaMap = {
    'Book a Strategy Call': 'CTA: drive them to book a free 15-min strategy call at goelev8.ai (link in bio)',
    'DM us "AI" to learn more': 'CTA: ask them to DM the word AI to learn more',
    'Link in bio': 'CTA: generic "link in bio" to learn more',
    'Comment below': 'CTA: ask them to comment something specific below',
    'No CTA': 'No CTA — pure value/education post, end naturally'
  };

  return `Write a ${type} post for GoElev8.AI.

Platform: ${platformGuide[platform] || platform}
Target audience: ${nicheContext[niche] || niche}
Tone: ${tone}
CTA direction: ${ctaMap[cta] || cta}
${msg ? `Additional angle/message to include: ${msg}` : ''}

Remember: No fabricated client results or specific numbers we can't back up yet. Lead with pain points, logic, and vivid scenarios instead. Make it feel real and urgent.`;
}

async function generatePost() {
  const type = document.getElementById('content-type').value;
  const niche = document.querySelector('.niche-btn.selected')?.textContent || 'General';
  const platform = document.getElementById('platform-select').value;
  const tone = document.getElementById('tone-select').value;
  const cta = document.getElementById('cta-select').value;
  const msg = document.getElementById('key-message').value;

  const output = document.getElementById('generated-output');
  const actions = document.getElementById('post-actions');
  const genBtn = document.getElementById('gen-btn');

  output.textContent = '';
  output.classList.add('loading');
  actions.style.display = 'none';
  genBtn.disabled = true;
  genBtn.textContent = '⏳ Generating...';

  const apiKey = document.getElementById('api-key-input').value.trim();
  if (!apiKey) {
    output.textContent = '⚠️ Please enter your Claude API key above to generate posts.\n\nGet yours free at console.anthropic.com';
    output.classList.remove('loading');
    genBtn.disabled = false;
    genBtn.textContent = '⚡ Generate Post with AI';
    return;
  }

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'anthropic-version': '2023-06-01', 'x-api-key': apiKey },
      body: JSON.stringify({
        model: 'claude-haiku-4-5-20251001',
        max_tokens: 1000,
        system: SYSTEM_PROMPT,
        messages: [{
          role: 'user',
          content: buildUserPrompt(type, niche, platform, tone, cta, msg)
        }]
      })
    });

    const data = await response.json();

    if (data.error) throw new Error(data.error.message);

    const content = data.content?.[0]?.text || '';
    output.classList.remove('loading');

    // Typewriter effect on real output
    let i = 0;
    output.textContent = '';
    const timer = setInterval(() => {
      output.textContent += content[i];
      i++;
      if (i >= content.length) {
        clearInterval(timer);
        actions.style.display = 'flex';
        updatePreview(content, niche);
        showScore(content);
      }
    }, 8);

  } catch (err) {
    output.classList.remove('loading');
    output.textContent = `⚠️ Error: ${err.message}\n\nMake sure your Claude API key is active at console.anthropic.com`;
    output.style.color = 'var(--red)';
    setTimeout(() => output.style.color = '', 100);
  } finally {
    genBtn.disabled = false;
    genBtn.textContent = '⚡ Generate Post with AI';
  }
}

function showScore(content) {
  // Score based on real content signals
  const hasHook = /^[^\n]{0,80}\n/.test(content);
  const hasEmoji = /[\u{1F300}-\u{1FFFF}]/u.test(content);
  const hasHashtags = /#\w+/.test(content);
  const lineBreaks = (content.match(/\n/g) || []).length;
  const hookScore = hasHook ? 88 + Math.floor(Math.random() * 10) : 72;
  const ctaScore = content.toLowerCase().includes('link in bio') || content.toLowerCase().includes('dm') || content.toLowerCase().includes('book') ? 85 + Math.floor(Math.random() * 12) : 65;
  const brandScore = content.toLowerCase().includes('goelev8') || content.toLowerCase().includes('ai') ? 90 + Math.floor(Math.random() * 8) : 80;
  const hashScore = hasHashtags ? 80 + Math.floor(Math.random() * 15) : 60;

  document.getElementById('score-area').innerHTML = `
    <div style="text-align:left">
      ${scoreRow('Hook Strength', hookScore)}
      ${scoreRow('CTA Clarity', ctaScore)}
      ${scoreRow('Brand Voice', brandScore)}
      ${scoreRow('Hashtag Mix', hashScore)}
    </div>
  `;
}

function scoreRow(label, score) {
  const color = score >= 85 ? 'var(--green)' : score >= 70 ? 'var(--cyan)' : 'var(--yellow)';
  return `
    <div style="margin-bottom:10px">
      <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
        <span>${label}</span><span style="color:${color}">${score}</span>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${score}%;background:${color};transition:width 0.8s ease"></div></div>
    </div>`;
}

function updatePreview(content, niche) {
  const lines = content.split('\n').filter(l => l.trim());
  const headline = lines[0]?.replace(/[\u{1F300}-\u{1FFFF}]/gu, '').trim() || 'YOUR CONTENT HERE';
  document.getElementById('ig-image').innerHTML = `<span style="color:var(--cyan);font-size:16px;line-height:1.4">${headline}</span>`;
  const caption = lines.slice(1, 4).join(' ').substring(0, 120) + '...';
  document.getElementById('ig-caption').textContent = caption;
}


